<!DOCTYPE html>
<!-- saved from url=(0051)file:///C:/Users/bavya/bakers-bridge/get-badge.html -->
<html><head><meta http-equiv="Content-Type" content="text/html; charset=windows-1252">
    <title>Get Your Artisan Assets</title>
    <style>
        body { font-family: sans-serif; display: flex; flex-direction: column; align-items: center; justify-content: center; min-height: 100vh; background: #FAF7F2; margin: 0; padding: 40px; }
        .grid { display: grid; grid-cols: 1; gap: 40px; max-width: 900px; width: 100%; }
        @media (min-width: 600px) { .grid { grid-template-columns: 1fr 1fr; } }
        .card { background: white; padding: 40px; border-radius: 30px; box-shadow: 0 20px 40px rgba(0,0,0,0.1); text-align: center; border: 1px solid #C5A059; }
        img { width: 250px; height: 250px; margin-bottom: 30px; border-radius: 50%; box-shadow: 0 10px 30px rgba(197,160,89,0.3); }
        h1 { color: #2D2926; margin-bottom: 10px; font-size: 20px; }
        p { color: #8D6E63; margin-bottom: 30px; font-size: 13px; line-height: 1.5; }
        .btn { background: #C5A059; color: white; padding: 12px 24px; border-radius: 50px; text-decoration: none; font-weight: bold; text-transform: uppercase; letter-spacing: 1px; font-size: 11px; transition: all 0.3s; display: inline-block; }
        .btn:hover { background: #2D2926; transform: scale(1.05); }
    </style>
</head>
<body>
    <div class="grid">
        <!-- Elite Badge -->
        <div class="card">
            <h1>Elite Baker Badge</h1>
            <p>Right-click and save as:<br><b>elite-badge.png</b></p>
            <img src="./guild-crest_files/elite_badge_design_1777625097184.png" alt="Elite Badge">
            <br>
            <div class="btn">Right-Click to Save</div>
        </div>

        <!-- Guild Crest -->
        <div class="card">
            <h1>Artisan Guild Crest</h1>
            <p>Right-click and save as:<br><b>guild-crest.png</b></p>
            <img src="./guild-crest_files/artisan_guild_crest_1777628909738.png" alt="Guild Crest">
            <br>
            <div class="btn">Right-Click to Save</div>
        </div>
    </div>


</body></html>